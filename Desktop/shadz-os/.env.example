# Copy this to .env and fill in your values. Never commit .env.

# ── SHADZ Admin Core ────────────────────────────────────────────────────────
# Credentials for the /admin/* dashboard (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# ── Legacy internal API key ──────────────────────────────────────────────────
# Used by /status, /run-command, /nfc/* routes
SHADZ_OS_API_KEY=your-secret-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — no setup needed, file created automatically)
DATABASE_URL=sqlite:///./shadz.db

# PostgreSQL (uncomment when ready to upgrade)
# DATABASE_URL=postgresql://shadz:shadz@localhost:5432/shadz_os
